    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: helenservice",
            "type": "debugpy",
            "request": "launch",
            "module": "helenservice.cli",
            "args": ["--debug"],
            "justMyCode": true
        },
        {
            "name": "pytest: all tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["-v"],
            "justMyCode": true
        },
        {
            "name": "pytest: current file",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["${file}", "-v"],
            "justMyCode": true
        }
    ]
}